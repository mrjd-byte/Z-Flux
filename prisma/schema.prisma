generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  isOnboarded  Boolean       @default(false)
  monthlyIncome Float        @default(0)
  walletId     String?       @unique
  walletBalance Float        @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  wallets      Wallet[]
  transactions Transaction[]
  budgets      Budget[]
  chatSessions ChatSession[]
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  friends          Friend[]        @relation("UserFriends")
  friendOf         Friend[]        @relation("FriendOf")
  socialScoreVisible Boolean      @default(true)
  notifications    Notification[]
  activities       Activity[]
}

model Wallet {
  id           String        @id @default(cuid())
  userId       String
  balance      Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // e.g., "INCOME", "EXPENSE", "TRANSFER_IN", "TRANSFER_OUT"
  description String   @default("")
  category    String   @default("General")
  subtype     String?
  userId      String
  senderId    String?
  receiverId  String?
  walletId    String
  fromWalletId String?
  toWalletId   String?
  createdAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  amount    Float
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String   @id @default(uuid())
  userId    String
  title     String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FriendRequest {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  status      String   @default("PENDING") // "PENDING", "ACCEPTED", "REJECTED"
  createdAt   DateTime @default(now())

  sender      User     @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId, status])
}

model Friend {
  id          String   @id @default(cuid())
  userId      String
  friendId    String
  createdAt   DateTime @default(now())

  user        User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend      User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  createdBy   String
  createdAt   DateTime @default(now())

  members       GroupMember[]
  contributions GroupContribution[]
  expenses      GroupExpense[]
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupContribution {
  id      String   @id @default(cuid())
  groupId String
  userId  String
  amount  Float
  createdAt DateTime @default(now())

  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupExpense {
  id        String   @id @default(cuid())
  groupId   String
  title     String
  amount    Float
  createdBy String
  createdAt DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "FRIEND_REQUEST", "GROUP_INVITE", "CONTRIBUTION", "EXPENSE"
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "FRIEND_ADDED", "CONTRIBUTION", "EXPENSE", "SCORE_UPDATE"
  message   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
